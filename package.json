{
  "name": "auto-embed",
  "version": "1.0.0",
  "description": "Zero-config CLI that ingests files into vector databases for RAG projects. Parse, chunk, embed, upsert — one command.",
  "type": "module",
  "bin": {
    "auto-embed": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "keywords": [
    "rag",
    "embeddings",
    "vector",
    "vector-database",
    "pgvector",
    "pinecone",
    "qdrant",
    "chroma",
    "openai",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@pinecone-database/pinecone": "^7.2.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "cheerio": "^1.2.0",
    "chromadb": "^3.4.3",
    "commander": "^14.0.0",
    "fastembed": "^2.1.0",
    "js-tiktoken": "^1.0.0",
    "mammoth": "^1.12.0",
    "mdast-util-to-string": "^4.0.0",
    "p-limit": "^6.0.0",
    "p-retry": "^7.0.0",
    "pg": "^8.21.0",
    "picocolors": "^1.1.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unpdf": "^1.6.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.7",
    "docx": "^9.7.1",
    "madge": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "tsup": "^8.5.0",
    "tsx": "^4.22.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  },
  "trustedDependencies": [
    "onnxruntime-node",
    "protobufjs"
  ]
}
